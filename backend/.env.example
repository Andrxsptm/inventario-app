# Conexión a la base de datos (Supabase)
# DATABASE_URL: URL con PGBouncer (puerto 6543) para transacciones
DATABASE_URL="postgresql://user:pass@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: URL directa (puerto 5432) para migraciones
DIRECT_URL="postgresql://user:pass@aws-0-region.pooler.supabase.com:5432/postgres"

# Credenciales de Supabase
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_ANON_KEY="tu-anon-key"

# Configuración del servidor
JWT_SECRET="cambia_este_secreto_en_produccion"
PORT=4000
